<script>
  import { calculate } from '~/lib/calc';
  import { track } from '~/scripts/app';

  function initBillSlider() {
    const range = document.querySelector<HTMLInputElement>('[data-bs-range]');
    if (!range || range.dataset.bound) return;
    range.dataset.bound = '1';

    const out = (k: string) => document.querySelector<HTMLElement>(`[data-bs="${k}"]`)!;
    const link = document.querySelector<HTMLAnchorElement>('[data-bs-link]')!;
    let tracked = false;

    const render = () => {
      const bill = Number(range.value);
      const pct = ((bill - Number(range.min)) / (Number(range.max) - Number(range.min))) * 100;
      range.style.setProperty('--fill', `${pct}%`);
      out('bill').textContent = `Rs ${bill.toLocaleString('en-PK')}`;
      const r = calculate({ bill, citySlug: 'lahore', type: 'home', battery: true });
      if (!r) return;
      out('newBill').textContent = `Rs ${r.newBillLow.toLocaleString('en-PK')}–${r.newBillHigh.toLocaleString('en-PK')}`;
      out('size').textContent = String(r.sizeKw);
      out('payback').textContent =
        r.paybackHigh > 25 ? '8+ yrs' : `${r.paybackLow}–${r.paybackHigh} yrs`;
      link.href = `/calculator?bill=${bill}`;
      if (!tracked) {
        tracked = true;
        track('slider_use', {});
      }
    };
    range.addEventListener('input', render);
    render();
  }

  document.addEventListener('astro:page-load', initBillSlider);
</script>
