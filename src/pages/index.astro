---
import { Image } from 'astro:assets';
import Layout from '~/layouts/Layout.astro';
import Icon from '~/components/Icon.astro';
import SectionHead from '~/components/SectionHead.astro';
import CTABand from '~/components/CTABand.astro';
import { site } from '~/config/site';
import { PACKAGES, PRICES_AS_OF, PAYBACK_TYPICAL } from '~/data/facts';
import { cities } from '~/data/cities';

import heroHome from '~/assets/photos/hero-home.jpg';
import roofLahore from '~/assets/photos/roof-lahore.jpg';
import heroBusiness from '~/assets/photos/hero-business.jpg';

const title = 'RaySmartSolar — Solar that kills the bill. Lahore & all major cities';
const description =
  'Solar installation for Pakistani homes and businesses — honest savings math under the 2026 net-billing rules, Tier-1 hardware with verifiable serials, and every page of the LESCO / NEPRA paperwork handled. Lahore-based. Free survey.';

const teaserPackages = PACKAGES.filter((p) => [3, 5, 10].includes(p.kw));

const fears = [
  {
    icon: 'pin' as const,
    fear: '“They took the advance and disappeared.”',
    answer: `We have a real office you can walk into — ${site.address.full} — and payments are staged against delivered work, never lump-sum up front.`,
  },
  {
    icon: 'shield' as const,
    fear: '“The panels weren’t what they promised.”',
    answer:
      'Every panel’s serial number is verified in the manufacturer’s own app, with you watching, before we leave the roof. Datasheets and warranty cards go in your file.',
  },
  {
    icon: 'trending' as const,
    fear: '“The savings were oversold.”',
    answer:
      'We quote ranges, not fantasies — sized for the 2026 net-billing rules, not the dead 1:1 net-metering math. Every assumption is printed on your proposal (and in our calculator).',
  },
  {
    icon: 'filecheck' as const,
    fear: '“The net-metering file never moved.”',
    answer:
      'We submit complete, first-time-right applications, chase your DISCO weekly, and tell you the honest current timeline before you sign — not after.',
  },
];

const steps = [
  {
    n: '01',
    title: 'Free survey & straight talk',
    body: 'We measure the roof, check your sanctioned load and shading, and read your actual bills. If solar doesn’t make sense for you yet, we say so — that honesty is cheaper than your regret.',
    meta: 'Same-week in Lahore',
  },
  {
    n: '02',
    title: 'A written quote you can hold us to',
    body: 'Named panel and inverter models, serial-verified Tier-1 hardware, taxes and government fees itemised separately, savings shown as ranges with the assumptions printed.',
    meta: 'Valid 14 days, price-locked',
  },
  {
    n: '03',
    title: 'Install day — done properly',
    body: 'Certified crew, engineered mounting, real earthing, DC cabling that won’t cook in August. The monitoring app goes on your account, not ours.',
    meta: '1–2 days for most homes',
  },
  {
    n: '04',
    title: 'Paperwork & power-on',
    body: 'We file your complete DISCO / NEPRA prosumer application, chase it weekly, and keep you posted. Meter installed, system commissioned, savings begin.',
    meta: 'DISCO timelines vary — we quote them honestly',
  },
];
---

<Layout {title} {description} heroNav>
  <!-- ═══════════════════ HERO ═══════════════════ -->
  <section class="hero theme-night" data-hero>
    <div class="hero-media" data-hero-media aria-hidden="true">
      <Image
        src={heroHome}
        alt=""
        widths={[480, 800, 1200, 1600, 2400]}
        sizes="100vw"
        format="avif"
        quality={62}
        loading="eager"
        fetchpriority="high"
        class="hero-img"
      />
      <div class="hero-scrim"></div>
    </div>
    <div class="hero-glow" data-hero-glow aria-hidden="true"></div>

    <div class="wrap hero-content">
      <p class="eyebrow mb-5" data-hero-stage style="--stage:0">
        Solar, done properly · Pakistan
      </p>
      <h1 class="font-display text-display max-w-[13ch] text-balance" data-hero-title>
        The sun doesn’t do load&#8209;shedding.
      </h1>
      <p class="text-lede text-ink-2 max-w-xl mt-6" data-hero-stage style="--stage:1">
        Cut your bill by up to <strong class="text-ink">90%</strong>, keep the fans turning through
        every outage — and we file every page of the {site.homeDisco} paperwork under the
        <strong class="text-ink">real 2026 rules</strong>.
      </p>

      <div class="mt-9 flex flex-wrap items-center gap-3.5" data-hero-stage style="--stage:2">
        <a
          href="/calculator"
          class="btn btn-gold btn-lg w-full sm:w-auto"
          data-evt="calc_open"
          data-evt-src="hero"
        >
          <Icon name="calculator" size={19} /> See my savings
        </a>
        <a href="#bill-slider" class="btn btn-ghost btn-lg w-full sm:w-auto" data-evt="hero_secondary">
          Try the 10-second version <Icon name="chevron-down" size={18} />
        </a>
      </div>

      <ul class="hero-chips mt-10" data-hero-stage style="--stage:3">
        <li class="chip"><Icon name="filecheck" size={15} class="text-gold" /> Net-metering file handled, start to finish</li>
        <li class="chip"><Icon name="shield" size={15} class="text-gold" /> Tier-1 panels, serials you can verify</li>
        <li class="chip"><Icon name="pin" size={15} class="text-gold" /> A Lahore office you can visit</li>
      </ul>
    </div>

    <div class="hero-cue" data-hero-stage style="--stage:4" aria-hidden="true">
      <span class="hero-cue-line"></span>
      <span class="font-mono text-[0.65rem] tracking-[0.25em] uppercase text-ink-3">Scroll</span>
    </div>
  </section>

  <!-- ═══════════════ HONEST NUMBERS ═══════════════ -->
  <section class="section">
    <div class="wrap">
      <SectionHead
        eyebrow="The honest math"
        title="Numbers first. Sales talk never."
        titleHtml="Numbers first. <em>Sales talk</em> never."
        lede="Pakistan’s tariffs are brutal and its sunshine is free — solar here pays back faster than almost anywhere on earth. Here’s the honest shape of it, before you give us a single detail."
      />
      <div class="grid gap-4 sm:grid-cols-3 mt-12" data-reveal-group>
        <div class="card p-7" data-reveal-child>
          <p class="mono-num text-5xl text-accent">
            <span data-count-to="90">0</span><span class="text-3xl">%</span>
          </p>
          <p class="mt-3 text-ink-2">
            of a typical bill gone — right-sized system with evening storage. Even without a
            battery, most homes clear half.
          </p>
        </div>
        <div class="card p-7" data-reveal-child>
          <p class="mono-num text-5xl text-accent">
            <span data-count-to="3">0</span><span class="text-3xl">–5 yrs</span>
          </p>
          <p class="mt-3 text-ink-2">
            typical payback at today’s tariffs. After that: ~20 years of essentially free daytime
            power.
          </p>
        </div>
        <div class="card p-7" data-reveal-child>
          <p class="mono-num text-5xl text-accent">
            <span data-count-to="25">0</span><span class="text-3xl">yrs</span>
          </p>
          <p class="mt-3 text-ink-2">
            performance warranty on Tier-1 panels — written, manufacturer-backed, serial-verifiable.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══════════════ BILL SLIDER TEASER ═══════════════ -->
  <section class="section pt-0" id="bill-slider">
    <div class="wrap max-w-3xl">
      <div class="card p-7 sm:p-10 slider-card" data-reveal>
        <p class="eyebrow mb-3">The 10-second answer</p>
        <h2 class="font-display text-h3">Drag your bill. Watch it shrink.</h2>

        <div class="mt-8">
          <div class="flex items-baseline justify-between gap-4 flex-wrap">
            <p class="text-sm text-ink-3">Your monthly bill</p>
            <p class="mono-num text-3xl text-ink" data-bs="bill">Rs 25,000</p>
          </div>
          <input
            type="range"
            min="8000"
            max="200000"
            step="1000"
            value="25000"
            class="bill-range mt-3"
            aria-label="Monthly electricity bill in rupees"
            data-bs-range
          />
        </div>

        <div class="grid grid-cols-2 sm:grid-cols-3 gap-4 mt-8">
          <div>
            <p class="text-xs font-mono uppercase tracking-[0.16em] text-ink-3">New bill ≈</p>
            <p class="mono-num text-xl sm:text-2xl text-money mt-1" data-bs="newBill">—</p>
          </div>
          <div>
            <p class="text-xs font-mono uppercase tracking-[0.16em] text-ink-3">System</p>
            <p class="mono-num text-xl sm:text-2xl mt-1"><span data-bs="size">—</span> kW</p>
          </div>
          <div class="col-span-2 sm:col-span-1">
            <p class="text-xs font-mono uppercase tracking-[0.16em] text-ink-3">Pays back in</p>
            <p class="mono-num text-xl sm:text-2xl mt-1" data-bs="payback">—</p>
          </div>
        </div>

        <p class="text-xs text-ink-3 mt-6">
          Quick estimate — Lahore home with evening battery, 2026 net-billing rules. The full
          calculator shows every assumption.
        </p>
        <a
          href="/calculator"
          class="btn btn-gold mt-5"
          data-bs-link
          data-evt="calc_open"
          data-evt-src="slider"
        >
          Open the honest calculator <Icon name="arrow-right" size={17} />
        </a>
      </div>
    </div>
  </section>

  <!-- ═══════════════ FORK: HOME / BUSINESS ═══════════════ -->
  <section class="section pt-0">
    <div class="wrap">
      <SectionHead
        eyebrow="Two different problems"
        title="A house feels the outage. A business counts it."
        lede="Different pains, different math, different paperwork — so we treat them as different worlds."
      />
      <div class="grid gap-5 md:grid-cols-2 mt-12" data-reveal-group>
        <a href="/homes" class="fork-card ph" data-reveal-child data-evt="fork" data-evt-kind="homes">
          <Image
            src={roofLahore}
            alt="Solar panels installed on a flat concrete rooftop in Lahore"
            widths={[480, 800, 1200]}
            sizes="(min-width: 768px) 50vw, 100vw"
            format="avif"
            quality={60}
            loading="lazy"
          />
          <div class="fork-body">
            <p class="eyebrow mb-2">For your home</p>
            <p class="font-display text-h3">Sleep through the outage. Watch the bill shrink.</p>
            <span class="fork-cta">Solar for homes <Icon name="arrow-right" size={17} /></span>
          </div>
        </a>
        <a href="/business" class="fork-card ph" data-reveal-child data-evt="fork" data-evt-kind="business">
          <Image
            src={heroBusiness}
            alt="Large solar array at sunset"
            widths={[480, 800, 1200]}
            sizes="(min-width: 768px) 50vw, 100vw"
            format="avif"
            quality={60}
            loading="lazy"
          />
          <div class="fork-body">
            <p class="eyebrow mb-2">For your business</p>
            <p class="font-display text-h3">Your biggest overhead, turned into an asset.</p>
            <span class="fork-cta">Solar for business <Icon name="arrow-right" size={17} /></span>
          </div>
        </a>
      </div>
    </div>
  </section>

  <!-- ═══════════════ JOURNEY ═══════════════ -->
  <section class="section" id="journey" data-scene="steps">
    <div class="wrap">
      <SectionHead
        eyebrow="How it works"
        title="From first call to a meter that finally behaves."
        lede="Four steps. You’ll know exactly where things stand at every one of them — starting with whether solar even makes sense for you."
      />
      <div class="journey mt-14">
        <div class="journey-line" aria-hidden="true"><span data-steps-line></span></div>
        <ol class="journey-list">
          {
            steps.map((s) => (
              <li class="journey-step" data-reveal>
                <div class="journey-dot" aria-hidden="true">
                  <span class="mono-num">{s.n}</span>
                </div>
                <div class="journey-card card p-6 sm:p-7">
                  <div class="flex flex-wrap items-baseline justify-between gap-2">
                    <h3 class="font-display text-h3">{s.title}</h3>
                    <p class="font-mono text-[0.7rem] uppercase tracking-[0.15em] text-accent">{s.meta}</p>
                  </div>
                  <p class="text-ink-2 mt-3 max-w-2xl">{s.body}</p>
                </div>
              </li>
            ))
          }
        </ol>
      </div>
      <div class="mt-10 flex justify-center" data-reveal>
        <a href="/quote" class="btn btn-gold btn-lg" data-evt="quote_open" data-evt-src="journey">
          Start with the free survey <Icon name="arrow-right" size={18} />
        </a>
      </div>
    </div>
  </section>

  <!-- ═══════════════ METER SCROLLY (2026 rules) ═══════════════ -->
  <section class="meter-scene theme-night" data-scene="meter">
    <div class="meter-pin" data-meter-pin>
      <div class="wrap meter-layout">
        <div class="meter-copy">
          <p class="eyebrow mb-4">Net metering, 2026 edition</p>
          <h2 class="font-display text-h2 max-w-[16ch]">
            The rules changed. <em class="fx-it">Our math changed with them.</em>
          </h2>
          <div class="meter-captions">
            <p class="meter-caption" data-meter-caption>
              <strong class="text-ink">Daytime:</strong> your roof runs the house directly — every
              unit you don’t buy saves you the full Rs 40–65. Leftovers export to the grid for a
              small credit.
            </p>
            <p class="meter-caption" data-meter-caption>
              <strong class="text-ink">Evening:</strong> the battery carries fans, lights and Wi-Fi
              through peak hours and outages — the expensive units you’d otherwise buy back from
              the grid.
            </p>
            <p class="meter-caption" data-meter-caption>
              <strong class="text-ink">Month end:</strong> a bill that finally behaves — and every
              page of the prosumer paperwork was ours to handle, not yours.
            </p>
          </div>
          <a href="/net-metering" class="link-gold inline-flex items-center gap-1.5 mt-2 font-medium" data-evt="netmetering_more">
            How the 2026 rules actually work <Icon name="arrow-up-right" size={15} />
          </a>
        </div>

        <div class="meter-stage" aria-hidden="true">
          <svg viewBox="0 0 520 420" fill="none" class="meter-svg">
            <!-- sun -->
            <g data-meter-sun>
              <circle cx="260" cy="78" r="26" fill="url(#sunfill)"></circle>
              <g stroke="var(--gold)" stroke-width="2.5" stroke-linecap="round" opacity="0.85">
                <path d="M260 34v-12M300 46l8-8M220 46l-8-8M312 78h12M208 78h-12"></path>
              </g>
            </g>
            <!-- house -->
            <g stroke="var(--n-text)" stroke-width="2.5" stroke-linejoin="round" stroke-linecap="round">
              <path d="M52 232 116 180l64 52" opacity="0.9"></path>
              <path d="M66 232v84h100v-84" opacity="0.9"></path>
              <rect x="96" y="266" width="40" height="50" rx="3" fill="rgb(242 166 60 / 0.16)" stroke-opacity="0.9"></rect>
              <path d="M96 200h0" opacity="0"></path>
            </g>
            <!-- panels on house roof -->
            <g stroke="var(--gold)" stroke-width="2" opacity="0.95">
              <path d="M78 214 116 184l38 30" fill="rgb(242 166 60 / 0.1)"></path>
              <path d="M91 204l50 0M84 210l58 0" opacity="0.55"></path>
            </g>
            <!-- battery -->
            <g data-meter-batt>
              <rect x="182" y="286" width="34" height="30" rx="4" stroke="var(--green)" stroke-width="2.25" fill="rgb(76 215 135 / 0.08)"></rect>
              <path d="M191 281h16" stroke="var(--green)" stroke-width="2.25" stroke-linecap="round"></path>
              <path d="M195 294l-4 8h6l-4 8" stroke="var(--green)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" fill="none"></path>
            </g>
            <!-- meter -->
            <g>
              <rect x="234" y="238" width="88" height="78" rx="10" stroke="var(--n-text)" stroke-width="2.5" fill="rgb(17 26 49 / 0.85)"></rect>
              <rect x="248" y="254" width="60" height="26" rx="4" fill="#0A0F1E" stroke="rgb(242 166 60 / 0.4)" stroke-width="1.5"></rect>
              <text x="278" y="272" text-anchor="middle" font-family="Spline Sans Mono, monospace" font-size="15" fill="var(--gold)" data-meter-digits>640</text>
              <text x="278" y="299" text-anchor="middle" font-family="Spline Sans Mono, monospace" font-size="9" letter-spacing="2" fill="var(--n-text-3)">UNITS · MONTH</text>
              <circle cx="278" cy="308" r="2.5" fill="var(--green)"></circle>
            </g>
            <!-- pylon -->
            <g stroke="var(--n-text-2)" stroke-width="2.25" stroke-linecap="round" stroke-linejoin="round" opacity="0.9">
              <path d="M424 316 442 208h24l18 108M436 240h36M430 272h48M424 316h60"></path>
              <path d="M442 208l24 32m0-32-24 32" opacity="0.6"></path>
            </g>
            <!-- flows: house -> meter -> grid (day export) -->
            <g data-meter-out stroke="var(--gold)" stroke-width="2.5" stroke-linecap="round">
              <path d="M170 254c22 0 40 6 58 6" stroke-dasharray="6 8" class="flow"></path>
              <path d="M326 268c34 0 62 10 90 22" stroke-dasharray="6 8" class="flow"></path>
              <path d="M410 284l12 8-14 4" fill="none"></path>
            </g>
            <!-- flows: battery -> house (evening) -->
            <g data-meter-in stroke="var(--green)" stroke-width="2.5" stroke-linecap="round">
              <path d="M196 282c0-18 -12-34 -30-42" stroke-dasharray="5 7" class="flow"></path>
              <path d="M172 246l-8-10 12-2" fill="none"></path>
            </g>
            <!-- ground -->
            <path d="M30 316h460" stroke="var(--n-line-strong)" stroke-width="2" stroke-linecap="round"></path>
            <defs>
              <radialGradient id="sunfill" cx="0.4" cy="0.35" r="1">
                <stop offset="0" stop-color="#FFD27A"></stop>
                <stop offset="1" stop-color="#F2A63C"></stop>
              </radialGradient>
            </defs>
          </svg>

          <!-- the month-end bill chip -->
          <div class="meter-bill card" data-meter-bill>
            <p class="text-[0.65rem] font-mono uppercase tracking-[0.18em] text-ink-3">Month-end bill</p>
            <p class="mono-num text-lg">
              <span class="line-through text-ink-3 decoration-danger/70">Rs 43,750</span>
              <span class="text-money ml-2">Rs 3,900</span>
            </p>
            <p class="text-[0.62rem] text-ink-3 mt-1">illustrative example — yours is computed honestly</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══════════════ PACKAGES TEASER ═══════════════ -->
  <section class="section">
    <div class="wrap">
      <SectionHead
        eyebrow={`Straight prices · ${PRICES_AS_OF}`}
        title="“5kW solar price?” Asked constantly. Answered here."
        lede="Turnkey bands for Tier-1 hardware, honestly ranged — because panel prices move with the dollar. Your exact quote gets locked in writing after the free survey."
      />
      <div class="grid gap-4 md:grid-cols-3 mt-12" data-reveal-group>
        {
          teaserPackages.map((p) => (
            <a href="/pricing" class="pkg card p-7 block" data-reveal-child data-evt="pkg_card" data-evt-kw={String(p.kw)}>
              <div class="flex items-baseline justify-between">
                <p class="mono-num text-5xl text-accent">
                  {p.kw}
                  <span class="text-2xl">kW</span>
                </p>
                <Icon name="arrow-up-right" size={20} class="text-ink-3 pkg-arrow" />
              </div>
              <p class="mono-num text-xl mt-4">
                Rs {(p.low / 100000).toFixed(1)} – {(p.high / 100000).toFixed(1)} lakh
              </p>
              <p class="text-sm text-ink-3 mt-1">installed · on-grid · Tier-1</p>
              <hr class="rule my-5" />
              <p class="text-sm text-ink-2">
                Fits bills around{' '}
                <strong class="text-ink">
                  Rs {Math.round(p.billLow / 1000)}–{Math.round(p.billHigh / 1000)}k
                </strong>
                /month ({p.unitsLow}–{p.unitsHigh} units)
              </p>
            </a>
          ))
        }
      </div>
      <div class="mt-8 flex flex-wrap items-center gap-4" data-reveal>
        <a href="/pricing" class="btn btn-ghost" data-evt="pricing_all">
          All sizes &amp; what’s inside the price <Icon name="arrow-right" size={16} />
        </a>
        <p class="text-sm text-ink-3">Hybrid &amp; battery options priced on the <a href="/pricing" class="link-gold">pricing page</a>.</p>
      </div>
    </div>
  </section>

  <!-- ═══════════════ TRUST / ANTI-SCAM ═══════════════ -->
  <section class="section theme-night trust-band">
    <div class="wrap">
      <SectionHead
        eyebrow="Let’s address it directly"
        title="You’ve heard the horror stories. So have we."
        lede="This market burned a lot of people — vanishing installers, relabeled panels, oversold savings, files that never moved. Here’s our answer to each, in writing."
      />
      <div class="grid gap-4 md:grid-cols-2 mt-12" data-reveal-group>
        {
          fears.map((f) => (
            <div class="card p-7 fear-card" data-reveal-child>
              <p class="font-display text-[1.2rem] leading-snug text-ink-2 italic">{f.fear}</p>
              <div class="flex items-start gap-3 mt-4">
                <span class="fear-icon">
                  <Icon name={f.icon} size={17} />
                </span>
                <p class="text-ink-2">
                  <strong class="text-ink">Our answer: </strong>
                  {f.answer}
                </p>
              </div>
            </div>
          ))
        }
      </div>

      <!-- Certifications bar — structure ready, owner supplies documents.
           See CONTENT-TODO.md §3. Never fake credentials. -->
      <div class="cert-bar card mt-6 p-6" data-reveal data-todo="certifications">
        <div class="flex flex-wrap items-center gap-x-8 gap-y-3">
          <p class="font-mono text-[0.68rem] uppercase tracking-[0.2em] text-ink-3">Credentials</p>
          <p class="text-sm text-ink-2 flex items-center gap-2">
            <Icon name="shield" size={15} class="text-gold" /> PPIB installer certification
            <span class="todo-chip">certificate № — being added</span>
          </p>
          <p class="text-sm text-ink-2 flex items-center gap-2">
            <Icon name="filecheck" size={15} class="text-gold" /> {site.homeDisco}-registered vendor
            <span class="todo-chip">docs on request</span>
          </p>
          <p class="text-sm text-ink-2 flex items-center gap-2">
            <Icon name="users" size={15} class="text-gold" /> Verify us in person — {site.address.area}, {site.address.city}
          </p>
        </div>
      </div>

      <p class="mt-6 text-sm text-ink-3 max-w-2xl" data-reveal>
        Customer reviews will appear here as they come in — real ones, with names and dates, never
        purchased. Until then: come meet us, or WhatsApp us hard questions. We like those.
      </p>
    </div>
  </section>

  <!-- ═══════════════ CITIES ═══════════════ -->
  <section class="section">
    <div class="wrap">
      <SectionHead
        eyebrow="Where we work"
        title="Local sun, local rules, local answers."
        lede="Every DISCO behaves differently — timelines, paperwork, moods. Each city page is written for its own grid, not copy-pasted."
      />
      <div class="grid gap-3 sm:grid-cols-2 lg:grid-cols-5 mt-10" data-reveal-group>
        {
          cities.map((c) => (
            <a href={`/${c.slug}`} class="city-card card p-5" data-reveal-child data-evt="city_card" data-evt-city={c.slug}>
