---
import { getCollection, render } from 'astro:content';
import type { CollectionEntry } from 'astro:content';
import { Image } from 'astro:assets';
import type { ImageMetadata } from 'astro';
import Layout from '~/layouts/Layout.astro';
import Prose from '~/components/Prose.astro';
import CTABand from '~/components/CTABand.astro';
import Icon from '~/components/Icon.astro';
import { site } from '~/config/site';

import hwMacro from '~/assets/photos/hw-macro.jpg';
import metersNew from '~/assets/photos/meters-new.jpg';
import roofAerial from '~/assets/photos/roof-aerial.jpg';
import hwBattery from '~/assets/photos/hw-battery.jpg';
import commWarehouse from '~/assets/photos/comm-warehouse.jpg';
import fieldSunset from '~/assets/photos/field-sunset.jpg';
import cityLahore3 from '~/assets/photos/city-lahore-3.jpg';
import skySun from '~/assets/photos/sky-sun.jpg';
import duskArray from '~/assets/photos/dusk-array.jpg';
import roofLahore from '~/assets/photos/roof-lahore.jpg';
import metersOld from '~/assets/photos/meters-old.jpg';
import pylon from '~/assets/photos/pylon.jpg';

export async function getStaticPaths() {
  const posts = await getCollection('learn');
  return posts.map((post) => ({ params: { slug: post.id }, props: { post } }));
}

interface Props {
  post: CollectionEntry<'learn'>;
}
const { post } = Astro.props;
const { Content } = await render(post);

/** photo key (frontmatter `cover`) → imported asset + alt text */
const covers: Record<string, { img: ImageMetadata; alt: string }> = {
  'hw-macro': { img: hwMacro, alt: 'Close-up of solar panel cells' },
  'meters-new': { img: metersNew, alt: 'Bank of modern smart electricity meters' },
  'roof-aerial': { img: roofAerial, alt: 'Aerial view of solar panels on rooftops' },
  'hw-battery': { img: hwBattery, alt: 'Technician installing a battery and inverter for a solar system' },
  'comm-warehouse': { img: commWarehouse, alt: 'Aerial view of a large solar array on a commercial rooftop' },
  'field-sunset': { img: fieldSunset, alt: 'Solar panels in a field at sunset' },
  'city-lahore-3': { img: cityLahore3, alt: 'Birds flying over a domed building in Lahore' },
  'sky-sun': { img: skySun, alt: 'Sunlight breaking through clouds' },
  'dusk-array': { img: duskArray, alt: 'Solar array under a dusk sky' },
  'roof-lahore': { img: roofLahore, alt: 'Solar panels on a flat concrete rooftop in Lahore' },
  'meters-old': { img: metersOld, alt: 'Old electricity meters on the wall of an old building' },
  pylon: { img: pylon, alt: 'Transmission pylon against a sunset sky' },
};
const cover = covers[post.data.cover] ?? covers['field-sunset'];

/** Same reading order as the hub. */
const ORDER = [
  'buyers-guide',
  'solar-prices-pakistan-2026',
  'net-metering-2026',
  'how-many-solar-panels',
  'on-grid-hybrid-off-grid',
  'solar-for-business-roi',
];
const rank = (id: string) => (ORDER.indexOf(id) === -1 ? 99 : ORDER.indexOf(id));
const all = await getCollection('learn');
const ordered = [...all].sort((a, b) => rank(a.id) - rank(b.id) || a.data.title.localeCompare(b.data.title));
const idx = ordered.findIndex((p) => p.id === post.id);
const keepReading = [ordered[(idx + 1) % ordered.length], ordered[(idx + 2) % ordered.length]].filter(
  (p) => p && p.id !== post.id
);

const fmtDate = (iso: string) =>
  new Date(`${iso}T00:00:00Z`).toLocaleDateString('en-GB', {
    day: 'numeric',
    month: 'long',
    year: 'numeric',
    timeZone: 'UTC',
  });

const title = post.data.title.length <= 42 ? `${post.data.title} | RaySmartSolar` : post.data.title;
const description = post.data.description;
const pageUrl = new URL(`/learn/${post.id}`, site.url).href;

const jsonLd = [
  {
    '@context': 'https://schema.org',
    '@type': 'Article',
    headline: post.data.title,
    description: post.data.description,
    datePublished: post.data.updated,
    dateModified: post.data.updated,
    author: { '@type': 'Organization', name: site.name, url: site.url },
    publisher: { '@id': `${site.url}/#business` },
    image: new URL(cover.img.src, site.url).href,
    mainEntityOfPage: pageUrl,
  },
];
---

<Layout {title} {description} {jsonLd}>
  <article>
    <header class="pt-28 lg:pt-36">
      <div class="wrap max-w-2xl">
        <p class="eyebrow mb-4" data-reveal>
          <a href="/learn" class="hover:underline underline-offset-4">Learn</a> · {post.data.tag}
        </p>
        <h1 class="font-display text-h2 text-balance" data-reveal>{post.data.title}</h1>
        <p class="font-mono text-[0.7rem] uppercase tracking-[0.16em] text-ink-3 mt-5" data-reveal>
          Updated {fmtDate(post.data.updated)} · {post.data.readingTime} min read
        </p>
        <div class="note mt-7" data-reveal>
          <p class="m-0"><strong class="text-ink">The short answer: </strong>{post.data.tldr}</p>
        </div>
      </div>
      <div class="wrap max-w-3xl mt-10" data-reveal>
        <figure class="ph rounded-2xl cover-frame m-0">
          <Image
            src={cover.img}
            alt={cover.alt}
            widths={[480, 800, 1200]}
            sizes="(min-width: 768px) 50vw, 100vw"
            format="avif"
            quality={60}
            loading="lazy"
          />
        </figure>
      </div>
    </header>

    <section class="section pt-12 sm:pt-16">
      <div class="wrap max-w-2xl">
        <Prose>
          <Content />
        </Prose>
      </div>
    </section>
  </article>

  <section class="section pt-0">
    <div class="wrap">
      <div class="flex items-baseline justify-between gap-4 flex-wrap">
        <h2 class="font-display text-h3">Keep reading</h2>
        <a href="/learn" class="link-gold inline-flex items-center gap-1.5 text-sm font-medium">
          All guides <Icon name="arrow-right" size={15} />
        </a>
      </div>
      <div class="grid gap-4 md:grid-cols-2 mt-6">
        {
          keepReading.map((p) => (
            <a
              href={`/learn/${p.id}`}
              class="next-card card p-6 flex flex-col"
              data-evt="learn_open"
              data-evt-slug={p.id}
            >
              <p class="eyebrow mb-3">{p.data.tag}</p>
              <p class="font-display text-h3 text-balance">{p.data.title}</p>
              <span class="next-more">
                {p.data.readingTime} min read
                <Icon name="arrow-right" size={15} />
              </span>
            </a>
          ))
        }
      </div>
    </div>
  </section>

  <section class="section pt-0">
    <div class="wrap">
      <CTABand
        heading="Numbers checked. Roof next?"
        sub="Run your bill through the calculator, then take the free survey — written quote, honest DISCO timeline, zero pressure."
        evtSrc="learn_article"
      />
    </div>
  </section>
</Layout>

<style>
  /* Honesty box for the tl;dr — same recipe as Prose's .note callout. */
  .note {
    background: color-mix(in srgb, var(--gold) 8%, transparent);
    border: 1px solid color-mix(in srgb, var(--gold) 30%, transparent);
    border-radius: 0.9rem;
    padding: 1rem 1.2rem;
    color: var(--text-2);
    font-size: 0.98rem;
    line-height: 1.65;
  }
  .cover-frame {
    aspect-ratio: 16 / 9;
  }
  @media (min-width: 768px) {
    .cover-frame {
      aspect-ratio: 2.3 / 1;
    }
  }
  .cover-frame :global(img) {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }
  .next-card {
    transition: transform 300ms var(--ease-out), border-color 200ms;
  }
  .next-card:hover {
    transform: translateY(-3px);
    border-color: color-mix(in srgb, var(--gold) 40%, transparent);
  }
  .next-more {
    display: inline-flex;
    align-items: center;
    gap: 0.45rem;
    color: var(--accent-text);
    font-weight: 550;
    font-size: 0.9rem;
    margin-top: auto;
    padding-top: 1.1rem;
  }
</style>
