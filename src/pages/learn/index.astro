---
import { getCollection } from 'astro:content';
import { Image } from 'astro:assets';
import type { ImageMetadata } from 'astro';
import Layout from '~/layouts/Layout.astro';
import PageHero from '~/components/PageHero.astro';
import CTABand from '~/components/CTABand.astro';
import Icon from '~/components/Icon.astro';

import hwMacro from '~/assets/photos/hw-macro.jpg';
import metersNew from '~/assets/photos/meters-new.jpg';
import roofAerial from '~/assets/photos/roof-aerial.jpg';
import hwBattery from '~/assets/photos/hw-battery.jpg';
import commWarehouse from '~/assets/photos/comm-warehouse.jpg';
import fieldSunset from '~/assets/photos/field-sunset.jpg';
import cityLahore3 from '~/assets/photos/city-lahore-3.jpg';
import skySun from '~/assets/photos/sky-sun.jpg';
import duskArray from '~/assets/photos/dusk-array.jpg';
import roofLahore from '~/assets/photos/roof-lahore.jpg';
import metersOld from '~/assets/photos/meters-old.jpg';
import pylon from '~/assets/photos/pylon.jpg';

const title = 'Learn solar — honest guides for Pakistan | RaySmartSolar';
const description =
  'Plain-English guides to solar prices, the 2026 net-billing rules, sizing and scam-spotting — written for Pakistani homes and businesses doing their homework.';

/** photo key (frontmatter `cover`) → imported asset + alt text */
const covers: Record<string, { img: ImageMetadata; alt: string }> = {
  'hw-macro': { img: hwMacro, alt: 'Close-up of solar panel cells' },
  'meters-new': { img: metersNew, alt: 'Bank of modern smart electricity meters' },
  'roof-aerial': { img: roofAerial, alt: 'Aerial view of solar panels on rooftops' },
  'hw-battery': { img: hwBattery, alt: 'Technician installing a battery and inverter for a solar system' },
  'comm-warehouse': { img: commWarehouse, alt: 'Aerial view of a large solar array on a commercial rooftop' },
  'field-sunset': { img: fieldSunset, alt: 'Solar panels in a field at sunset' },
  'city-lahore-3': { img: cityLahore3, alt: 'Birds flying over a domed building in Lahore' },
  'sky-sun': { img: skySun, alt: 'Sunlight breaking through clouds' },
  'dusk-array': { img: duskArray, alt: 'Solar array under a dusk sky' },
  'roof-lahore': { img: roofLahore, alt: 'Solar panels on a flat concrete rooftop in Lahore' },
  'meters-old': { img: metersOld, alt: 'Old electricity meters on the wall of an old building' },
  pylon: { img: pylon, alt: 'Transmission pylon against a sunset sky' },
};
const coverOf = (key: string) => covers[key] ?? covers['field-sunset'];

/** Reading order: the guide first, then the homework sequence. */
const ORDER = [
  'buyers-guide',
  'solar-prices-pakistan-2026',
  'net-metering-2026',
  'how-many-solar-panels',
  'on-grid-hybrid-off-grid',
  'solar-for-business-roi',
];
const rank = (id: string) => (ORDER.indexOf(id) === -1 ? 99 : ORDER.indexOf(id));

const all = await getCollection('learn');
const posts = [...all].sort((a, b) => rank(a.id) - rank(b.id) || a.data.title.localeCompare(b.data.title));
const featured = posts.find((p) => p.id === 'buyers-guide');
const rest = posts.filter((p) => p.id !== 'buyers-guide');

const fmtMonth = (iso: string) =>
  new Date(`${iso}T00:00:00Z`).toLocaleDateString('en-GB', { month: 'long', year: 'numeric', timeZone: 'UTC' });
---

<Layout {title} {description}>
  <PageHero
    eyebrow="The learning hub"
    title="Do your homework. We’ll wait."
    titleHtml="Do your homework. <em>We’ll wait.</em>"
    lede="Straight guides to prices, the 2026 rules, sizing and scam-spotting — written to be useful even if you never call us. Read first, decide later; the sun isn’t going anywhere."
  />

  <section class="section pt-10 sm:pt-14">
    <div class="wrap">
      {
        featured && (
          <a
            href="/guide"
            class="feat card overflow-hidden grid md:grid-cols-[1.1fr_1fr]"
            data-reveal
            data-evt="guide_open"
            data-evt-src="learn_hub"
          >
            <figure class="ph feat-media m-0">
              <Image
                src={coverOf(featured.data.cover).img}
                alt={coverOf(featured.data.cover).alt}
                widths={[480, 800, 1200]}
                sizes="(min-width: 768px) 50vw, 100vw"
                format="avif"
                quality={60}
                loading="lazy"
              />
            </figure>
            <div class="p-7 sm:p-9 flex flex-col">
              <p class="eyebrow mb-4">{featured.data.tag} · Start here</p>
              <h2 class="font-display text-h3 sm:text-[1.7rem] sm:leading-[1.15] text-balance">{featured.data.title}</h2>
              <p class="text-ink-2 mt-4">{featured.data.tldr}</p>
              <p class="font-mono text-[0.68rem] uppercase tracking-[0.14em] text-ink-3 mt-5">
                {featured.data.readingTime} min read · Updated {fmtMonth(featured.data.updated)}
              </p>
              <span class="btn btn-gold mt-7 self-start">
                <Icon name="download" size={17} /> Get the free guide
              </span>
            </div>
          </a>
        )
      }

      <div class="grid gap-4 md:grid-cols-2 lg:grid-cols-3 mt-5" data-reveal-group>
        {
          rest.map((p) => (
            <a
              href={`/learn/${p.id}`}
              class="learn-card card overflow-hidden flex flex-col"
              data-reveal-child
              data-evt="learn_open"
              data-evt-slug={p.id}
            >
              <figure class="ph learn-media m-0">
                <Image
                  src={coverOf(p.data.cover).img}
                  alt={coverOf(p.data.cover).alt}
                  widths={[480, 800, 1200]}
                  sizes="(min-width: 768px) 50vw, 100vw"
                  format="avif"
                  quality={60}
                  loading="lazy"
                />
              </figure>
              <div class="p-6 flex flex-col grow">
                <p class="eyebrow mb-3">{p.data.tag}</p>
                <h2 class="font-display text-h3 text-balance">{p.data.title}</h2>
                <p class="text-ink-2 text-[0.95rem] mt-3">{p.data.tldr}</p>
                <p class="font-mono text-[0.68rem] uppercase tracking-[0.14em] text-ink-3 mt-auto pt-5">
                  {p.data.readingTime} min read · Updated {fmtMonth(p.data.updated)}
                </p>
              </div>
            </a>
          ))
        }
      </div>

      <p class="text-sm text-ink-3 mt-8 max-w-2xl" data-reveal>
        Every number in these guides carries its “as of” date, and the volatile ones get re-checked
        at your free survey. Where the market disagrees with itself, we print the range — not the
        prettiest end of it.
      </p>
    </div>
  </section>

  <section class="section pt-0">
    <div class="wrap">
      <CTABand
        heading="Homework done? Let’s see your numbers."
        sub="The calculator runs your bill under the 2026 rules with every assumption printed. The survey after it is free — and optional."
        evtSrc="learn_final"
      />
    </div>
  </section>
</Layout>

<style>
  .feat {
    transition: transform 300ms var(--ease-out), border-color 200ms;
  }
  .feat:hover {
    transform: translateY(-4px);
    border-color: color-mix(in srgb, var(--gold) 45%, transparent);
  }
  .feat-media {
    min-height: 14rem;
  }
  .feat-media :global(img) {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }
  @media (min-width: 768px) {
    .feat-media {
      height: 100%;
    }
  }
  .learn-card {
    transition: transform 300ms var(--ease-out), border-color 200ms;
  }
  .learn-card:hover {
    transform: translateY(-4px);
    border-color: color-mix(in srgb, var(--gold) 40%, transparent);
  }
  .learn-media {
    aspect-ratio: 16 / 9;
  }
  .learn-media :global(img) {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }
</style>
