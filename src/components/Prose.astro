---
/** Long-form typography wrapper for articles & legal pages. */
interface Props {
  class?: string;
}
const { class: className = '' } = Astro.props;
---

<div class:list={['prose-rss', className]}>
  <slot />
</div>

<style is:global>
  .prose-rss {
    max-width: 42rem;
    color: var(--text-2);
    font-size: 1.04rem;
    line-height: 1.75;
  }
  .prose-rss h2 {
    font-family: var(--font-display);
    color: var(--text);
    font-size: clamp(1.45rem, 2vw + 1rem, 1.9rem);
    line-height: 1.2;
    font-weight: 530;
    letter-spacing: -0.01em;
    margin: 2.6em 0 0.7em;
  }
  .prose-rss h3 {
    font-family: var(--font-display);
    color: var(--text);
    font-size: 1.2rem;
    font-weight: 560;
    margin: 2em 0 0.55em;
  }
  .prose-rss p {
    margin-block: 1em;
  }
  .prose-rss strong {
    color: var(--text);
    font-weight: 620;
  }
  .prose-rss a {
    color: var(--accent-text);
    text-decoration: underline;
    text-underline-offset: 3px;
    text-decoration-color: color-mix(in srgb, var(--gold) 50%, transparent);
  }
  .prose-rss ul,
  .prose-rss ol {
    margin: 1em 0 1em 1.3em;
    display: grid;
    gap: 0.45em;
  }
  .prose-rss ul {
    list-style: none;
  }
  .prose-rss ul > li {
    position: relative;
    padding-left: 1.15rem;
  }
  .prose-rss ul > li::before {
    content: '';
    position: absolute;
    left: 0;
    top: 0.62em;
    width: 6px;
    height: 6px;
    border-radius: 999px;
    background: var(--gold);
  }
  .prose-rss ol {
    list-style: decimal;
  }
  .prose-rss ol > li::marker {
    color: var(--accent-text);
    font-family: var(--font-mono);
  }
  .prose-rss blockquote {
    border-left: 2px solid var(--gold);
    padding: 0.4em 0 0.4em 1.2em;
    margin: 1.6em 0;
    font-family: var(--font-display);
    font-style: italic;
    font-size: 1.15em;
    color: var(--text);
  }
  .prose-rss table {
    width: 100%;
    border-collapse: collapse;
    margin: 1.6em 0;
    font-size: 0.95em;
  }
  .prose-rss th {
    text-align: left;
    font-family: var(--font-mono);
    font-size: 0.72em;
    text-transform: uppercase;
    letter-spacing: 0.14em;
    color: var(--text-3);
    padding: 0.6em 0.9em;
    border-bottom: 1px solid var(--line-strong);
  }
  .prose-rss td {
    padding: 0.7em 0.9em;
    border-bottom: 1px solid var(--line);
    color: var(--text-2);
  }
  .prose-rss td:first-child {
    color: var(--text);
    font-weight: 540;
  }
  .prose-rss .mono-num {
    font-family: var(--font-mono);
  }
  .prose-rss hr {
    border: 0;
    height: 1px;
    background: linear-gradient(90deg, transparent, var(--line-strong), transparent);
    margin: 2.4em 0;
  }
  /* callout boxes for honesty notes */
  .prose-rss .note {
    background: color-mix(in srgb, var(--gold) 8%, transparent);
    border: 1px solid color-mix(in srgb, var(--gold) 30%, transparent);
    border-radius: 0.9rem;
    padding: 1rem 1.2rem;
    margin: 1.6em 0;
    font-size: 0.95em;
  }
</style>
