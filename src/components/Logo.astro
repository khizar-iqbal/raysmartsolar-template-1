---
interface Props {
  /** Height of the mark in px */
  size?: number;
  wordmark?: boolean;
  class?: string;
}
const { size = 30, wordmark = true, class: className = '' } = Astro.props;
---

<span class:list={['logo inline-flex items-center gap-2.5 select-none', className]}>
  <svg
    width={size}
    height={size}
    viewBox="0 0 32 32"
    fill="none"
    aria-hidden="true"
    class="logo-mark"
  >
    <!-- rising sun: half-disc + meter-tick rays -->
    <defs>
      <linearGradient id="lg-sun" x1="6" y1="8" x2="26" y2="24" gradientUnits="userSpaceOnUse">
        <stop offset="0" stop-color="#FFD27A"></stop>
        <stop offset="1" stop-color="#F2A63C"></stop>
      </linearGradient>
    </defs>
    <path d="M8.4 20a7.6 7.6 0 1 1 15.2 0Z" fill="url(#lg-sun)"></path>
    <path
      d="M16 6.2V3.4M8.9 9.1 7 7.2M23.1 9.1 25 7.2M5.8 14.6l-2.6-.7M26.2 14.6l2.6-.7"
      stroke="url(#lg-sun)"
      stroke-width="2"
      stroke-linecap="round"></path>
    <path d="M4 24h24" stroke="currentColor" stroke-width="2" stroke-linecap="round" opacity="0.9"
    ></path>
    <path d="M9 28h14" stroke="currentColor" stroke-width="2" stroke-linecap="round" opacity="0.35"
    ></path>
  </svg>
  {
    wordmark && (
      <span class="font-sans font-semibold tracking-tight text-[1.12rem] leading-none">
        <span class="text-gold">Ray</span>SmartSolar
      </span>
    )
  }
</span>
