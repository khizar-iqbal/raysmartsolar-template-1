# ── Lead delivery ─────────────────────────────────────────────
# Get a key at https://resend.com (free tier is enough to start).
# Without a key the site runs in DRY-RUN mode: leads are logged to
# .leads/leads.jsonl and the console instead of being emailed.
RESEND_API_KEY=

# Where leads are delivered. Keep byte-identical with site config.
LEAD_TO_EMAIL=info@raysmartsolar.com

# The "from" address. Until raysmartsolar.com is verified in Resend,
# use onboarding@resend.dev (works out of the box for testing).
LEAD_FROM_EMAIL=RaySmartSolar Leads <onboarding@resend.dev>

# ── Site ──────────────────────────────────────────────────────
PUBLIC_SITE_URL=https://raysmartsolar.com

# ── Analytics ─────────────────────────────────────────────────
# "on" enables the event tracker (and Plausible if you add the snippet).
# Anything else = events log to console in dev, no-op in prod.
PUBLIC_ANALYTICS=off
